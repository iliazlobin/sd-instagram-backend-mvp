# ============================================================
# Instagram MVP — environment variables
# ============================================================
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env
#
# All variables are read by src/instagram/config.py (pydantic-settings).
# Defaults shown below match the compose setup (db service on compose net).

# Database connection URL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://instagram:instagram@db:5432/instagram

# Server bind host (0.0.0.0 inside container, localhost for sandbox)
HOST=0.0.0.0
PORT=8000

# App host port mapping — overrides the compose ports short-syntax default.
# Compose publishes ${APP_PORT:-8010}:8000, so setting this changes the
# host-side port only; the in-container port is always 8000.
APP_PORT=8010

# Media storage — directory for uploaded images
MEDIA_DIR=media

# Maximum upload size in bytes (10 MB default)
MAX_UPLOAD_BYTES=10485760

# Feed pagination defaults
FEED_DEFAULT_LIMIT=20
FEED_MAX_LIMIT=100
FEED_BACKFILL_COUNT=20

# Search pagination defaults
SEARCH_DEFAULT_LIMIT=20
SEARCH_MAX_LIMIT=100
