# ============================================================
# verify/manifest.env — canonical CI & host e2e contract
# ============================================================
# Sourced by CI workflows and the host e2e loop.  Do NOT edit
# to green-light a failing build — fix the *system* instead.
# Format: VAR="value" with shell-safe quoting.

# Bring the stack up (compose must be in PATH).
# --wait is intentionally avoided: its behaviour across Docker Compose versions is
# unreliable (some versions return immediately, others hang or exit non-zero too
# early).  We rely on the explicit READY loop below instead.
UP="docker compose up -d"

# Wait for /healthz to return 200 (up to 60 attempts, 1 s apart).
# The DB container (postgres:16-alpine) needs ~15-30 s cold-start; the app
# container starts after the DB and must apply migrations + bind uvicorn.
READY="ready=0; for i in \$(seq 1 60); do if curl -sf http://localhost:\${APP_PORT:-8010}/healthz; then ready=1; break; fi; sleep 1; done; if [ \"\$ready\" != 1 ]; then echo 'ERROR: /healthz did not become ready within 60s'; docker compose logs --tail=50; exit 1; fi"

# Run the black-box acceptance suite (API_BASE_URL must match the compose port)
ACCEPTANCE="pytest verify/acceptance/ -v"

# Tear down the stack, removing volumes to start fresh next run
DOWN="docker compose down -v"

# Install test dependencies (same as pyproject.toml [dev] extras)
TEST_DEPS="pip install pytest pytest-asyncio httpx"
